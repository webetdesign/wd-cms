{% for block in blocks %}
    <div class="{{ block.size | default('col-md-6') }}">
        {% include block.template with block.data %}
    </div>
    <div id="data-{{ block.name }}" style="display: none;" data-values="{{ block.data | json_encode }}">
    </div>

{% endfor %}

{% if colors is defined %}
    <div id="colors" style="display: none;" data-colors="{{ colors }}">
    </div>
{% endif %}

{% if week_colors is defined %}
    <div id="week_colors" style="display: none;" data-weekcolors="{{ week_colors }}">
    </div>
{% endif %}

{% if year_colors is defined %}
    <div id="year_colors" style="display: none;" data-yearcolors="{{ year_colors }}">
    </div>
{% endif %}
